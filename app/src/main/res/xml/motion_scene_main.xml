<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:motion="http://schemas.android.com/apk/res-auto">

    <Transition
        motion:constraintSetStart="@id/start"
        motion:constraintSetEnd="@id/end"
        motion:duration="800"
        motion:autoTransition="animateToEnd">

        <KeyFrameSet>
            <!-- Shield icon: scale up + fade in first -->
            <KeyAttribute
                motion:motionTarget="@id/imgShield"
                motion:framePosition="0"
                android:alpha="0"
                android:scaleX="0.5"
                android:scaleY="0.5" />
            <KeyAttribute
                motion:motionTarget="@id/imgShield"
                motion:framePosition="40"
                android:alpha="1"
                android:scaleX="1.0"
                android:scaleY="1.0" />

            <!-- Title: fade in after shield -->
            <KeyAttribute
                motion:motionTarget="@id/tvTitle"
                motion:framePosition="0"
                android:alpha="0"
                android:translationY="20" />
            <KeyAttribute
                motion:motionTarget="@id/tvTitle"
                motion:framePosition="30"
                android:alpha="0"
                android:translationY="20" />
            <KeyAttribute
                motion:motionTarget="@id/tvTitle"
                motion:framePosition="55"
                android:alpha="1"
                android:translationY="0" />

            <!-- Subtitle: fade in after title -->
            <KeyAttribute
                motion:motionTarget="@id/tvSubtitle"
                motion:framePosition="0"
                android:alpha="0"
                android:translationY="15" />
            <KeyAttribute
                motion:motionTarget="@id/tvSubtitle"
                motion:framePosition="40"
                android:alpha="0"
                android:translationY="15" />
            <KeyAttribute
                motion:motionTarget="@id/tvSubtitle"
                motion:framePosition="65"
                android:alpha="1"
                android:translationY="0" />

            <!-- Card 1: slide up + fade in -->
            <KeyAttribute
                motion:motionTarget="@id/cardTimeSession"
                motion:framePosition="0"
                android:alpha="0"
                android:translationY="40" />
            <KeyAttribute
                motion:motionTarget="@id/cardTimeSession"
                motion:framePosition="50"
                android:alpha="0"
                android:translationY="40" />
            <KeyAttribute
                motion:motionTarget="@id/cardTimeSession"
                motion:framePosition="75"
                android:alpha="1"
                android:translationY="0" />

            <!-- Card 2: slide up + fade in -->
            <KeyAttribute
                motion:motionTarget="@id/cardRecurringSession"
                motion:framePosition="0"
                android:alpha="0"
                android:translationY="40" />
            <KeyAttribute
                motion:motionTarget="@id/cardRecurringSession"
                motion:framePosition="60"
                android:alpha="0"
                android:translationY="40" />
            <KeyAttribute
                motion:motionTarget="@id/cardRecurringSession"
                motion:framePosition="85"
                android:alpha="1"
                android:translationY="0" />

            <!-- Botão sessões ativas -->
            <KeyAttribute
                motion:motionTarget="@id/btnActiveSessions"
                motion:framePosition="0"
                android:alpha="0" />
            <KeyAttribute
                motion:motionTarget="@id/btnActiveSessions"
                motion:framePosition="75"
                android:alpha="0" />
            <KeyAttribute
                motion:motionTarget="@id/btnActiveSessions"
                motion:framePosition="100"
                android:alpha="1" />

            <!-- Botão ADB tutorial -->
            <KeyAttribute
                motion:motionTarget="@id/btnDeviceOwnerTutorial"
                motion:framePosition="0"
                android:alpha="0" />
            <KeyAttribute
                motion:motionTarget="@id/btnDeviceOwnerTutorial"
                motion:framePosition="80"
                android:alpha="0" />
            <KeyAttribute
                motion:motionTarget="@id/btnDeviceOwnerTutorial"
                motion:framePosition="100"
                android:alpha="1" />
        </KeyFrameSet>
    </Transition>

    <!-- Start: same as end (we use KeyFrames for the animation) -->
    <ConstraintSet android:id="@+id/start">
    </ConstraintSet>

    <ConstraintSet android:id="@+id/end">
    </ConstraintSet>

</MotionScene>
