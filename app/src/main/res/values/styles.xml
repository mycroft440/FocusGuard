<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark Minimalist Theme -->
    <style name="Theme.FocusGuard" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Dark background -->
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorSurface">@color/dark_surface</item>
        <!-- Primary accent: Cyan -->
        <item name="colorPrimary">@color/accent_cyan</item>
        <item name="colorPrimaryVariant">@color/accent_cyan_dark</item>
        <!-- Secondary accent -->
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorSecondaryVariant">@color/accent_cyan_dark</item>
        <!-- On colors -->
        <item name="colorOnPrimary">@color/dark_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/dark_bg</item>
        <item name="android:navigationBarColor">@color/dark_bg</item>
        <!-- EditText hint -->
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <!-- Gray Theme (kept for compatibility) -->
    <style name="Theme.FocusGuard.Gray" parent="Theme.FocusGuard" />
</resources>
