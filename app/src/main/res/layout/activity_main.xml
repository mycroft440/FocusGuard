<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground">

    <!-- Botão de Permissões Pendentes (Invisível por padrão) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPendingPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Dê o restante das permissões aqui"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:backgroundTint="#D32F2F"
        app:cornerRadius="12dp"
        android:visibility="gone"
        app:icon="@android:drawable/ic_dialog_alert"
        app:iconTint="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FocusGuard"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp" />

            <!-- Card: Sessão por Tempo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTimeSession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/dark_card"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_recent_history"
                        app:tint="?attr/colorPrimary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sessão de Bloqueio por Tempo"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Defina dias e horas para focar"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card: Sessão Recorrente -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecurringSession"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/dark_card"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="?attr/colorPrimary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sessão de Bloqueio Recorrente"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agende horários fixos na semana"
                        android:textColor="?android:attr/textColorSecondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botão de Sessões Ativas -->
            <Button
                android:id="@+id/btnActiveSessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ver Sessões Ativas"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginBottom="16dp"/>




        </LinearLayout>
    </ScrollView>
</LinearLayout>
