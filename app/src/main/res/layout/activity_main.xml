<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg">

    <!-- Botão de Permissões Pendentes (Invisível por padrão) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPendingPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="12dp"
        android:text="Dê o restante das permissões aqui"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="14sp"
        android:background="@drawable/btn_danger_bg"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:visibility="gone"
        android:stateListAnimator="@null"
        app:backgroundTint="@null"
        app:icon="@drawable/ic_warning"
        app:iconTint="@android:color/white"
        app:iconGravity="textStart"
        app:cornerRadius="16dp" />

    <!-- MotionLayout para animação de revelação staggered -->
    <androidx.constraintlayout.motion.widget.MotionLayout
        android:id="@+id/motionLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layoutDescription="@xml/motion_scene_main"
        app:showPaths="false">

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:fillViewport="true"
            android:scrollbars="none"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp"
                android:gravity="center_horizontal">

                <!-- Header com escudo -->
                <ImageView
                    android:id="@+id/imgShield"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_shield"
                    android:layout_marginTop="32dp"
                    android:layout_marginBottom="12dp"
                    android:contentDescription="Ícone FocusGuard"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FocusGuard"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Foco Total, Zero Distrações"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="32dp" />

                <!-- Card: Sessão por Tempo -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTimeSession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.FocusGuard.Card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/ic_timer"
                            android:layout_marginEnd="16dp"
                            android:contentDescription="Ícone de sessão por tempo"
                            android:importantForAccessibility="no" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sessão por Tempo"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Defina dias e horas para focar"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/text_hint"
                            android:contentDescription="Abrir"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Sessão Recorrente -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRecurringSession"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    style="@style/Widget.FocusGuard.Card"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@drawable/ic_calendar"
                            android:layout_marginEnd="16dp"
                            android:contentDescription="Ícone de sessão recorrente"
                            android:importantForAccessibility="no" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sessão Recorrente"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Agende horários fixos na semana"
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/text_hint"
                            android:contentDescription="Abrir"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/section_divider"
                    android:layout_marginBottom="24dp" />

                <!-- Botão de Sessões Ativas -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActiveSessions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver Sessões Ativas"
                    android:textColor="@color/accent_cyan"
                    style="@style/Widget.FocusGuard.Button.Outlined"
                    app:icon="@drawable/ic_sessions"
                    app:iconTint="@color/accent_cyan"
                    app:iconGravity="textStart"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp"
                    android:gravity="center">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeviceOwnerTutorial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROTEÇÃO NUCLEAR"
                        style="@style/Widget.FocusGuard.Button.Danger"
                        android:paddingStart="32dp"
                        android:paddingEnd="32dp"
                        app:icon="@drawable/ic_warning"
                        app:iconTint="@android:color/white"
                        app:iconSize="20dp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ative para que o bloqueio seja impossivel de burlar!!"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:textAlignment="center" />
                </LinearLayout>
        </ScrollView>

    </androidx.constraintlayout.motion.widget.MotionLayout>
</LinearLayout>
