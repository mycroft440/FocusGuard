<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Blocking Session"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:weightSum="2">

        <Button
            android:id="@+id/btnStartTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Set Start Time"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btnEndTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Set End Time"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <CheckBox
        android:id="@+id/chkRecurring"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Repeat Everyday (Recurring)"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"
        android:checked="false" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ Warning:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Once you start the blocking session:\n\n• Apps and websites will be blocked between these hours\n• If recurring, it will repeat daily\n• Device Owner will enforce restrictions during the window"
        android:textSize="12sp"
        android:layout_marginBottom="24dp"
        android:padding="12dp"
        android:background="@drawable/item_background"
        android:lineSpacingMultiplier="1.5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:spacing="8dp">

        <Button
            android:id="@+id/startButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Blocking"
            android:textColor="@color/white"
            android:backgroundTint="@color/red" />

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel" />

    </LinearLayout>

</LinearLayout>
